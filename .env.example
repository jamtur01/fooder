GOOGLE_PLACES_API_KEY=
HOME_LAT=37.4221
HOME_LNG=-122.0841
SEARCH_RADIUS_METERS=5000
DB_PATH=./fooder.db
PORT=3000

# Display names for the two sides (also become URL paths after slugification)
SIDE_A_NAME=A
SIDE_B_NAME=B

# Path to favorites JSON (cuisine id -> array of Google Place IDs).
# Optional — if missing, only Google search results populate the deck.
FAVORITES_FILE=./favorites.json

# Inline alternative to FAVORITES_FILE. Convenient on Railway etc.
# When set, takes precedence over FAVORITES_FILE.
# FAVORITES_JSON={"thai":["ChIJxxxx"],"chinese":["ChIJyyyy"]}
